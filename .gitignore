# Solo System RPG repository ignore rules

# Secrets and local environment
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.cert
*.p12
*.pfx

# Dependencies and package manager caches
node_modules/
.pnp/
.pnp.*
.npm/
.pnpm-store/
.yarn/*
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/sdks/
!.yarn/versions/
.bun/install/cache/

# Next.js, frontend, and build outputs
.next/
out/
dist/
build/
.output/
.turbo/
.parcel-cache/
.cache/
coverage/
*.tsbuildinfo

# Supabase local runtime state
supabase/.branches/
supabase/.temp/
supabase/.inbucket/

# Logs and diagnostic dumps
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
*.pid
*.seed
*.pid.lock

# Test and language tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
__pycache__/
*.py[cod]

# Editor, OS, and local workspace noise
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
*.swp
*.swo
*~
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.history/
.cursor/

# Obsidian local state. Vault Markdown and stable settings remain trackable.
.obsidian/workspace*.json
.obsidian/cache/
.obsidian/plugins/
.obsidian/snippets/
.trash/

# Agent/runtime local state. Project plugin manifests and skills remain trackable.
.agents/cache/
.agents/tmp/
.agents/logs/
.codex/
.claude/settings.local.json
.mcp.json

# Local scratch artifacts
/null
